{
  "name": "Flask App Codespace",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  
  // Menginstall dependencies secara otomatis saat Codespace dibuat
  "updateContentCommand": "pip install -r requirements.txt",

  // Menjalankan aplikasi Flask otomatis setelah Codespace berhasil terbuka
  "postStartCommand": "flask run --host=0.0.0.0 --port=5001",

  // Memastikan port 5000 dibuka dan bisa diakses via browser
  "forwardPorts": [5001],
  "portsAttributes": {
    "5001": {
      "label": "Flask Application",
      "onAutoForward": "openPreview"
    }
  }
}
